# Neon PostgreSQL (use pooled connection string from Neon dashboard)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Local dev / production app URL (used in email links)
BETTER_AUTH_URL=http://localhost:3000

# ─── Email: Mailjet (primary) ───────────────────────────────────────────────
# From Mailjet dashboard → Account Settings → REST API → API Key Management
MAILJET_API_KEY=
MAILJET_API_SECRET=
MAILJET_FROM_EMAIL=hello@safaricamplodge.com
MAILJET_FROM_NAME=Safari Camp Lodge

# ─── Email: Gmail SMTP (secondary fallback) ─────────────────────────────────
# Use a Google App Password (not your normal password):
# https://myaccount.google.com/apppasswords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=
GMAIL_FROM_EMAIL=your@gmail.com

# Inbox for contact form submissions (defaults to MAILJET_FROM_EMAIL)
CONTACT_INBOX_EMAIL=hello@safaricamplodge.com

# Optional overrides
# EMAIL_FROM=hello@safaricamplodge.com
# EMAIL_FROM_NAME=Safari Camp Lodge
# EMAIL_FORCE_PROVIDER=mailjet
# EMAIL_FORCE_PROVIDER=gmail
# EMAIL_FORCE_PROVIDER=log
# EMAIL_SEND_IN_DEV=true

# ─── Seed passwords (min 8 chars) — change before production ────────────────
# SEED_SUPER_ADMIN_PASSWORD=YourSuperAdminPassword
# SEED_ADMIN_PASSWORD=SafariAdmin2026!
# SEED_MANAGER_PASSWORD=SafariManager2026!
# SEED_STAFF_PASSWORD=SafariStaff2026!
